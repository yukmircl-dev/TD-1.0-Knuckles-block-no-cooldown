-- Configuración de la GUI
local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local Title = Instance.new("TextLabel")
local ActionBtn = Instance.new("TextButton")
local UICorner = Instance.new("UICorner")
local UIStroke = Instance.new("UIStroke")

-- Propiedades de la Ventana Principal
ScreenGui.Parent = game.CoreGui
ScreenGui.Name = "ZombieAbilityGui"

MainFrame.Name = "MainFrame"
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.Position = UDim2.new(0.5, -100, 0.5, -75)
MainFrame.Size = UDim2.new(0, 200, 0, 150)
MainFrame.Active = true
MainFrame.Draggable = true -- Para que puedas moverla

Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)

-- Título
Title.Parent = MainFrame
Title.BackgroundTransparency = 1
Title.Size = UDim2.new(1, 0, 0, 40)
Title.Font = Enum.Font.GothamBold
Title.Text = "ZOMBIE MOD"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 18

-- Botón de Acción
ActionBtn.Parent = MainFrame
ActionBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
ActionBtn.Position = UDim2.new(0.1, 0, 0.4, 0)
ActionBtn.Size = UDim2.new(0.8, 0, 0.4, 0)
ActionBtn.Font = Enum.Font.GothamSemibold
ActionBtn.Text = "Spam Ability Zombie"
ActionBtn.TextColor3 = Color3.fromRGB(0, 255, 127)
ActionBtn.TextSize = 14
ActionBtn.TextWrapped = true

Instance.new("UICorner", ActionBtn).CornerRadius = UDim.new(0, 8)

-- Lógica del Spam
local isSpaming = false

ActionBtn.MouseButton1Click:Connect(function()
    isSpaming = not isSpaming
    
    if isSpaming then
        ActionBtn.Text = "STOP"
        ActionBtn.TextColor3 = Color3.fromRGB(255, 50, 50)
        
        -- Ejecutar el spam en un hilo separado
        task.spawn(function()
            while isSpaming do
                local player = game:GetService("Players").LocalPlayer
                local character = player.Character
                
                if character then
                    local attack = character:FindFirstChild("Attack")
                    if attack then
                        local devour = attack:FindFirstChild("Devour")
                        if devour and devour:IsA("RemoteEvent") then
                            devour:FireServer()
                        end
                    end
                end
                task.wait(0.1) -- Ajusta la velocidad aquí (0.1 es rápido)
            end
        end)
    else
        ActionBtn.Text = "Spam Ability Zombie"
        ActionBtn.TextColor3 = Color3.fromRGB(0, 255, 127)
    end
end)
