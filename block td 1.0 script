-- Función generadora de botones
local function createAbilityButton(name, text, pos, remoteFunc)
    local btn = Instance.new("TextButton")
    local active = false
    
    btn.Name = name
    btn.Parent = MainFrame
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    btn.Position = pos
    btn.Size = UDim2.new(0.85, 0, 0, 55)
    btn.Font = Enum.Font.GothamSemibold
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(0, 255, 180)
    btn.TextSize = 12
    btn.TextWrapped = true
    
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    btn.MouseButton1Click:Connect(function()
        active = not active
        if active then
            btn.Text = "STOP " .. name:upper()
            btn.TextColor3 = Color3.fromRGB(255, 80, 80)
            btn.BackgroundColor3 = Color3.fromRGB(45, 30, 30)
            
            task.spawn(function()
                while active do
                    pcall(remoteFunc)
                    task.wait(0.1)
                end
            end)
        else
            btn.Text = text
            btn.TextColor3 = Color3.fromRGB(0, 255, 180)
            btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        end
    end)
end

