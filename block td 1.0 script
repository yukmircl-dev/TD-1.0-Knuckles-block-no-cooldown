-- Función para crear botones automáticamente
local function createAbilityButton(name, text, pos, remoteFunc)
    local btn = Instance.new("TextButton")
    local active = false
    
    btn.Name = name
    btn.Parent = MainFrame
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.Position = pos
    btn.Size = UDim2.new(0.85, 0, 0, 60)
    btn.Font = Enum.Font.GothamSemibold
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(0, 255, 150)
    btn.TextSize = 13
    btn.TextWrapped = true
    
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    
    btn.MouseButton1Click:Connect(function()
        active = not active
        if active then
            btn.Text = "STOP " .. name:upper()
            btn.TextColor3 = Color3.fromRGB(255, 70, 70)
            btn.BackgroundColor3 = Color3.fromRGB(50, 30, 30)
            
            task.spawn(function()
                while active do
                    pcall(remoteFunc)
                    task.wait(0.1)
                end
            end)
        else
            btn.Text = text
            btn.TextColor3 = Color3.fromRGB(0, 255, 150)
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        end
    end)
end

