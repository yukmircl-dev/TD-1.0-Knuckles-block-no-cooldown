local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local Title = Instance.new("TextLabel")
local ZombieBtn = Instance.new("TextButton")
local CorruptBtn = Instance.new("TextButton")

-- Propiedades de la Ventana Principal
ScreenGui.Parent = game.CoreGui
ScreenGui.Name = "CustomAbilityGui"

MainFrame.Name = "MainFrame"
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.Position = UDim2.new(0.5, -100, 0.5, -100)
MainFrame.Size = UDim2.new(0, 220, 0, 200) -- Un poco más grande para los 2 botones
MainFrame.Active = true
MainFrame.Selectable = true
MainFrame.Draggable = true

local MainCorner = Instance.new("UICorner", MainFrame)
MainCorner.CornerRadius = UDim.new(0, 10)

-- Título
Title.Parent = MainFrame
Title.BackgroundTransparency = 1
Title.Size = UDim2.new(1, 0, 0, 40)
Title.Font = Enum.Font.GothamBold
Title.Text = "ABILITY MANAGER"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 16

-- Función para crear botones con el mismo estilo
local function createButton(name, text, pos)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Parent = MainFrame
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.Position = pos
    btn.Size = UDim2.new(0.85, 0, 0, 50)
    btn.Font = Enum.Font.GothamSemibold
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(0, 255, 127)
    btn.TextSize = 13
    btn.TextWrapped = true
    
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    return btn
end

-- Crear Botones
local ZombieBtn = createButton("ZombieBtn", "Spam Ability Zombie", UDim2.new(0.075, 0, 0.25, 0))
local CorruptBtn = createButton("CorruptBtn", "Spam Ability Corrupted", UDim2.new(0.075, 0, 0.6, 0))

-- Lógica Zombie
local zombieSpam = false
ZombieBtn.MouseButton1Click:Connect(function()
    zombieSpam = not zombieSpam
    if zombieSpam then
        ZombieBtn.Text = "STOP"
        ZombieBtn.TextColor3 = Color3.fromRGB(255, 50, 50)
        task.spawn(function()
            while zombieSpam do
                pcall(function()
                    game:GetService("Players").LocalPlayer.Character.Attack.Devour:FireServer()
                end)
                task.wait(0.1)
            end
        end)
    else
        ZombieBtn.Text = "Spam Ability Zombie"
        ZombieBtn.TextColor3 = Color3.fromRGB(0, 255, 127)
    end
end)

-- Lógica Corrupted
local corruptSpam = false
CorruptBtn.MouseButton1Click:Connect(function()
    corruptSpam = not corruptSpam
